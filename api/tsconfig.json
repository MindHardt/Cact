{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "verbatimModuleSyntax": true,
    "composite": true,
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "rootDir": "src",
    "outDir": "dist",
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "references": [
    { "path": "../shared" }
  ],
  "include": ["src", ".drizzle"],
  "exclude": ["node_modules"]
}
